# API secrets (set via `wrangler secret put` for production)
# Spotify - https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Data API v3 - https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Frontend (only needed for local dev if API is on a different host)
VITE_API_URL=
